# Makevars — links socialchoicelab against the pre-built libscs_api.
#
# SCS_LIB_PATH must be set to the directory containing libscs_api.so/.dylib.
# Example (add to ~/.Renviron or set before calling install.packages):
#   SCS_LIB_PATH=/path/to/socialchoicelab/build
#
# For CI, the libscs_api artifact is downloaded and SCS_LIB_PATH is set by
# the workflow before running R CMD check.

SCS_LIB_PATH ?= $(error SCS_LIB_PATH is not set. Set it to the directory containing libscs_api.so or libscs_api.dylib)

PKG_CPPFLAGS = -I../../../include
PKG_LIBS     = -L$(SCS_LIB_PATH) -lscs_api -Wl,-rpath,$(SCS_LIB_PATH)
